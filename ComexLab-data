function startLesson(mod, topic) {
  curMod=mod; curTopic=topic;
  const key=mod+'_'+topic;
  const base=QB[key]||[];
  const ext=QB[key+'_ext']||[];
  const pool=[...base,...ext];
  // Shuffle and cap at 10 questions per session
  const shuffled=pool.sort(()=>Math.random()-0.5);
  questions=shuffled.slice(0,Math.min(10,shuffled.length));
  if(!questions.length){
    // fallback â¬ show coming soon
    nav('home');
    alert('Este tema está en desarrollo. Próximamente disponible.');
    return;
  }
  curQIdx=0; selOpt=-1; answered=false; lives=5; correct=0;
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('s-lesson').classList.add('active');
  document.getElementById('main').scrollTop=0;
  setActiveNav('home');
  toggleMobileNav(false);
  loadQ();
}

function loadQ() {
  if(curQIdx>=questions.length){showResults();return;}
  const q=questions[curQIdx];
  selOpt=-1; answered=false;

  // progress
  const pct=Math.round(curQIdx/questions.length*100);
  document.getElementById('les-prog').style.width=pct+'%';

  // module tag
  document.getElementById('les-module-tag').textContent=(MODULE_LABELS[curMod]||'')+' â¬º '+(TOPIC_LABELS[curTopic]||curTopic);

  // lives
  let lh='';
  for(let i=0;i<5;i++) lh+=`<span class="heart${i>=lives?' dead':''}">â¤ï¸</span>`;
  document.getElementById('lives-row').innerHTML=lh;

  // breadcrumb
  document.getElementById('breadcrumb').innerHTML=
    `<span>${MODULE_LABELS[curMod]||curMod}</span><span class="bc-sep">â¬º</span><span>${TOPIC_LABELS[curTopic]||curTopic}</span>`;

  // type badge
  const badgeEl=document.getElementById('q-badge');
  const types={opc:'opc',vof:'vof',caso:'caso',comp:'comp'};
  const labels={opc:'Opción múltiple',vof:'Verdadero o Falso',caso:'Caso Práctico',comp:'Completar'};
  badgeEl.className='q-badge '+(types[q.type]||'opc');
  badgeEl.textContent=labels[q.type]||'Opción múltiple';
  document.getElementById('q-counter').textContent=`${curQIdx+1} / ${questions.length}`;

  document.getElementById('q-text').textContent=q.text;
  const ctx=document.getElementById('q-ctx');
  ctx.textContent=q.ctx||'';
  ctx.style.display=q.ctx?'':'none';
  const snip=document.getElementById('q-snip');
  if(q.snip){snip.textContent=q.snip;snip.style.display='';}
  else snip.style.display='none';

  // options
  const letters=['A','B','C','D'];
  document.getElementById('opts').innerHTML=q.opts.map((o,i)=>
    `<button class="opt" id="o${i}" onclick="selO(${i})">
      <span class="opt-ltr">${letters[i]}</span><span>${o}</span>
    </button>`
  ).join('');

  // reset feedback & btn
  const fb=document.getElementById('feedback');
  fb.className='feedback';
  const hp=document.getElementById('help-panel');
  if(hp) hp.classList.remove('show');

  const btn=document.getElementById('btn-check');
  btn.textContent='Verificar respuesta';
  btn.className='btn-check idle';
  btn.disabled=true;
  btn.onclick=handleCheck;

  document.getElementById('q-area').style.display='';
  document.getElementById('ai-loader').style.display='none';
}

function selO(i) {
  if(answered)return;
  selOpt=i;
  document.querySelectorAll('.opt').forEach((b,idx)=>{
    b.className='opt'+(idx===i?' sel':'');
  });
  document.getElementById('btn-check').disabled=false;
}

function handleCheck() {
  if(answered||selOpt<0){nextQ();return;}
  answered=true;
  const q=questions[curQIdx];
  const isOk=selOpt===q.ok;

  document.querySelectorAll('.opt').forEach((b,i)=>{
    b.disabled=true;
    if(i===q.ok) b.className='opt ok';
    else if(i===selOpt&&!isOk) b.className='opt bad';
    else b.className='opt';
  });

  const fb=document.getElementById('feedback');
  fb.className=`feedback ${isOk?'ok':'bad'} show`;
  document.getElementById('fb-ico').textContent=isOk?'âS&':'âR';
  document.getElementById('fb-title').textContent=isOk?'¡Correcto!':'Incorrecto â¬ revisa la explicación';
  document.getElementById('fb-body').textContent=q.exp||'';
  const ref=document.getElementById('fb-ref');
  if(q.ref){ref.textContent='ðxR '+q.ref;ref.style.display='';}
  else ref.style.display='none';

  if(isOk){correct++;xp+=10;}
  else{
    lives--;
    let lh='';
    for(let i=0;i<5;i++) lh+=`<span class="heart${i>=lives?' dead':''}">â¤ï¸</span>`;
    document.getElementById('lives-row').innerHTML=lh;
  }

  // Quick AI buttons
  // Auto-show explanation after answering
  showHelp(isOk ? 'example' : 'errors');

  const btn=document.getElementById('btn-check');
  btn.textContent=curQIdx+1<questions.length?'Continuar â ':'Ver resultados';
  btn.className=`btn-check ${isOk?'next-ok':'next-bad'}`;
  btn.onclick=nextQ;
}

function nextQ(){curQIdx++;if(curQIdx>=questions.length)showResults();else loadQ();}

/* RESULTS */
function showResults() {
  nav('results');
  const acc=Math.round(correct/questions.length*100);
  const earned=correct*10+(acc===100?20:0);
  document.getElementById('res-trophy').textContent=acc>=90?'ðx ':acc>=70?'â­':acc>=50?'ðxª':'ðxa';
  document.getElementById('res-title').textContent=acc>=90?'¡Dominio total!':acc>=70?'¡Muy bien!':acc>=50?'Sigue practicando':'Repasa el tema';
  document.getElementById('res-sub').textContent=`${MODULE_LABELS[curMod]} â¬ ${TOPIC_LABELS[curTopic]}`;
  document.getElementById('res-xp').textContent=`+${earned} XP`;
  document.getElementById('rs-score').textContent=`${correct}/${questions.length}`;
  document.getElementById('rs-acc').textContent=`${acc}%`;
  document.getElementById('rs-lives').textContent=lives;
  xp+=earned;
  document.querySelector('.xp-label').textContent=xp+' XP';
}

