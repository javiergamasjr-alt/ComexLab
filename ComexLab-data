function validatePed(){
  const rules=[
    {id:'p-rfc',fn:v=>v&&v.length>=12&&v.length<=13,msg:'RFC debe tener 12 o 13 caracteres.'},
    {id:'p-razon',fn:v=>v&&v.length>3,msg:'Ingresa la razón social.'},
    {id:'p-frac',fn:v=>v&&/^\d{4}\.\d{2}\.\d{2}$/.test(v),msg:'Formato: 8471.30.01 (8 dígitos + puntos)'},
    {id:'p-nico',fn:v=>v&&/^\d{2}$/.test(v),msg:'NICO: exactamente 2 dígitos numéricos.'},
    {id:'p-desc',fn:v=>v&&v.length>3,msg:'Describe la mercancía.'},
    {id:'p-qty',fn:v=>v&&parseFloat(v)>0,msg:'Cantidad debe ser mayor a cero.'},
    {id:'p-um',fn:v=>!!v,msg:'Selecciona la unidad de medida.'},
    {id:'p-pais',fn:v=>!!v,msg:'Selecciona el país de origen.'},
    {id:'p-valor',fn:v=>v&&parseFloat(v)>0,msg:'El valor debe ser mayor a cero.'},
    {id:'p-aduana',fn:v=>!!v,msg:'Selecciona la aduana de entrada.'},
    {id:'p-clave',fn:v=>!!v,msg:'Selecciona la clave del pedimento.'},
    {id:'p-patente',fn:v=>v&&v.length===4&&/^\d+$/.test(v),msg:'Patente: exactamente 4 dígitos.'},
  ];
  let errors=[],oks=[];
  rules.forEach(r=>{
    const v=gv(r.id),el=document.getElementById(r.id);
    if(r.fn(v)){el.className='fi ok';oks.push(r.id);}
    else{el.className='fi err';errors.push(r);}
  });
  const badge=document.getElementById('ped-badge');
  const res=document.getElementById('val-results');
  res.style.display='';
  if(!errors.length){
    badge.textContent='âS Válido';badge.className='ped-status ok';
    res.innerHTML=`<div style="background:rgba(34,197,94,0.07);border:1px solid rgba(34,197,94,0.28);border-radius:6px;padding:0.85rem;margin-bottom:6px"><div style="font-size:13px;font-weight:700;color:#15803D;margin-bottom:3px">âS& Pedimento válido</div><div style="font-size:12px;color:#6B7280">Todos los campos correctos. En producción este pedimento podría transmitirse al sistema VUCEM del SAT.</div></div>`;
  } else {
    badge.textContent=errors.length+' error(es)';badge.className='ped-status err';
    res.innerHTML=`<div style="background:rgba(255,77,77,0.08);border:1px solid rgba(255,77,77,0.25);border-radius:6px;padding:0.85rem;margin-bottom:6px"><div style="font-size:13px;font-weight:700;color:#B91C1C;margin-bottom:3px">âa ï¸ ${errors.length} error(es)</div></div>`
      +errors.map(e=>`<div class="val-item"><span class="val-ico">âR</span><span class="val-msg"><strong>${e.id.replace('p-','').toUpperCase()}:</strong> ${e.msg}</span></div>`).join('');
  }
}

function resetPed(){
  ['p-rfc','p-razon','p-frac','p-nico','p-desc','p-qty','p-valor'].forEach(id=>{
    const el=document.getElementById(id);if(el){el.value='';el.className='fi';}
  });
  ['p-pais','p-um','p-aduana','p-clave'].forEach(id=>{
    const el=document.getElementById(id);if(el){el.selectedIndex=0;el.className='fi';}
  });
  document.getElementById('p-tc').value='17.50';
  document.getElementById('p-igi').value='15';
  document.getElementById('p-tratado').selectedIndex=0;
  document.getElementById('ped-badge').textContent='Borrador';
  document.getElementById('ped-badge').className='ped-status draft';
  document.getElementById('val-results').innerHTML='';
  document.getElementById('val-results').style.display='none';
  upd();
}

